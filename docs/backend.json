
{
  "entities": {
    "Patient": {
      "title": "Patient Profile",
      "description": "Basic information for a clinical patient",
      "type": "object",
      "properties": {
        "regNo": { "type": "string" },
        "name": { "type": "string" },
        "dob": { "type": "string", "format": "date" },
        "age": { "type": "number" },
        "sex": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "branch": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastVisit": { "type": "string", "format": "date" },
        "type": { "type": "string", "enum": ["In-patient", "Out-patient"] },
        "status": { "type": "string", "enum": ["admitted", "registry", "waiting", "review", "billing", "completed"] },
        "treatmentAmount": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid"] },
        "settledAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone"]
    },
    "Assessment": {
      "title": "Health Assessment Form",
      "description": "Comprehensive medical and Ayurvedic assessment record",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "chiefComplaints": { "type": "string" },
        "duration": { "type": "string" },
        "associateComplaints": { "type": "string" },
        "disorders": { "type": "object" },
        "history": { "type": "object" },
        "ayurvedic": { "type": "object" },
        "doctorChief": { "type": "string" },
        "consultationNotes": { "type": "string" },
        "prescription": { "type": "string" },
        "workoutPlan": { "type": "string" },
        "nextVisitDate": { "type": "string", "format": "date" },
        "suggestedServices": { "type": "string" }
      }
    },
    "Appointment": {
      "title": "Online Appointment",
      "description": "Booking request from the website contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "service": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "admitted", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "assignedDoctor": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["emailPassword"]
  },
  "firestore": {
    "/patients/{patientId}": {
      "schema": { "$ref": "#/backend/entities/Patient" },
      "description": "Patient directory"
    },
    "/patients/{patientId}/assessments/{assessmentId}": {
      "schema": { "$ref": "#/backend/entities/Assessment" },
      "description": "Clinical assessments for a patient"
    },
    "/appointments/{appointmentId}": {
      "schema": { "$ref": "#/backend/entities/Appointment" },
      "description": "Online booking requests and clinic queue"
    }
  }
}
